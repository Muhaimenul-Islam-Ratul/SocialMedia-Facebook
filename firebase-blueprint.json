{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "User's first name" },
        "lastName": { "type": "string", "description": "User's last name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["firstName", "lastName", "email", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string", "description": "UID of the post author" },
        "authorName": { "type": "string", "description": "Full name of the author" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author" },
        "content": { "type": "string", "description": "Text content of the post" },
        "imageUrl": { "type": "string", "description": "Optional image URL for the post" },
        "isPublic": { "type": "boolean", "description": "Whether the post is visible to everyone" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was created" },
        "likeCount": { "type": "number", "description": "Total number of likes" },
        "commentCount": { "type": "number", "description": "Total number of comments" }
      },
      "required": ["authorId", "authorName", "content", "isPublic", "createdAt", "likeCount", "commentCount"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string", "description": "ID of the parent post" },
        "authorId": { "type": "string", "description": "UID of the comment author" },
        "authorName": { "type": "string", "description": "Full name of the author" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author" },
        "content": { "type": "string", "description": "Text content of the comment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the comment was created" },
        "likeCount": { "type": "number", "description": "Total number of likes on the comment" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt", "likeCount"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post or comment",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who liked" },
        "targetId": { "type": "string", "description": "ID of the post or comment being liked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the like was created" }
      },
      "required": ["userId", "targetId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/posts/{postId}": { "schema": "Post", "description": "Social media posts" },
    "/comments/{commentId}": { "schema": "Comment", "description": "Comments on posts" },
    "/likes/{likeId}": { "schema": "Like", "description": "Likes on posts and comments" }
  }
}
