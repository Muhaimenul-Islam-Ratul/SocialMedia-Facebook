# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Express + MongoDB API
API_PORT="4000"
CLIENT_ORIGIN="http://localhost:3000,https://facebok-8xfdvtlte-ratuls-projects-fa1c2aa1.vercel.app"
MONGODB_URI="mongodb://127.0.0.1:27017/socialfeed"
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me-too"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="7"
COOKIE_SECURE="false"

# Optional Cloudinary image upload support
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
